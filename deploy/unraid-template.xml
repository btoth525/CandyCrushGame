<?xml version="1.0"?>
<!--
  Unraid Community Applications template.

  HOW TO USE:
    1. Build and push the image to a registry (Docker Hub or GHCR):
         docker build -t YOURNAME/wizarding-nuts:latest .
         docker push YOURNAME/wizarding-nuts:latest
    2. In Unraid, edit this file and set <Repository> to YOURNAME/wizarding-nuts:latest
    3. Copy this file to /boot/config/plugins/dockerMan/templates-user/
    4. Open the Docker tab, click "Add Container", choose "Wizarding-Nuts" template.
-->
<Container version="2">
  <Name>Wizarding-Nuts</Name>
  <Repository>yourname/wizarding-nuts:latest</Repository>
  <Registry>https://hub.docker.com/</Registry>
  <Network>bridge</Network>
  <Privileged>false</Privileged>
  <Support/>
  <Project/>
  <Overview>Charles &amp; Brandon's Wizarding World of Nuts -- a match-3 web game.</Overview>
  <Category>GameServers: Other:</Category>
  <WebUI>http://[IP]:[PORT:80]/</WebUI>
  <TemplateURL/>
  <Icon>https://raw.githubusercontent.com/btoth525/CandyCrushGame/claude/match-3-game-SHJ92/game/icons/icon-512.png</Icon>
  <ExtraParams/>
  <PostArgs/>
  <CPUset/>
  <DateInstalled>0</DateInstalled>
  <DonateText/>
  <DonateLink/>
  <Description>A spellbound match-3 adventure starring nuts of the wizarding world. Static site served by nginx; works as a PWA so users can install it to their phone home screen.</Description>
  <Networking>
    <Mode>bridge</Mode>
    <Publish>
      <Port>
        <HostPort>8080</HostPort>
        <ContainerPort>80</ContainerPort>
        <Protocol>tcp</Protocol>
      </Port>
    </Publish>
  </Networking>
  <Data/>
  <Environment/>
  <Labels/>
  <Config Name="WebUI Port" Target="80" Default="8080" Mode="tcp" Description="Port the game is served on" Type="Port" Display="always" Required="true" Mask="false">8080</Config>
</Container>

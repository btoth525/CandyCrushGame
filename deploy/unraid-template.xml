<?xml version="1.0"?>
<!--
  Unraid Community Applications template for Wizarding Nuts (server mode).

  This template runs the FULL stack in a single container:
    - The match-3 game (static frontend)
    - The admin panel
    - The /api/* backend (accounts, leaderboards, cloud save, daily challenge)
    - SQLite database persisted to /mnt/user/appdata/wizarding-nuts/

  HOW TO INSTALL:
    1. Build and push the image to Docker Hub or GHCR ONE TIME from the repo root:
         docker build -f server/Dockerfile -t YOURNAME/wizarding-nuts:latest .
         docker push YOURNAME/wizarding-nuts:latest
       (Or run `docker compose up -d --build` from the repo on Unraid directly.)
    2. Edit the <Repository> tag below to your image.
    3. Copy this file to /boot/config/plugins/dockerMan/templates-user/
    4. Open the Docker tab -> "Add Container" -> choose "Wizarding-Nuts" template.
    5. Set ADMIN_TOKEN to a long random string -- this unlocks "Push to Server"
       in the admin panel.
    6. Apply. Visit http://[UNRAID-IP]:8080
-->
<Container version="2">
  <Name>Wizarding-Nuts</Name>
  <Repository>yourname/wizarding-nuts:latest</Repository>
  <Registry>https://hub.docker.com/</Registry>
  <Network>bridge</Network>
  <Privileged>false</Privileged>
  <Support/>
  <Project/>
  <Overview>Charles &amp; Brandon's Wizarding World of Nuts -- a match-3 web game with global leaderboards, accounts, cloud save sync, daily challenges, and a GUI admin panel. Single container: frontend + admin + Node API + SQLite all in one.</Overview>
  <Category>GameServers: Other:</Category>
  <WebUI>http://[IP]:[PORT:3000]/</WebUI>
  <TemplateURL/>
  <Icon>https://raw.githubusercontent.com/btoth525/CandyCrushGame/claude/match-3-game-SHJ92/game/icons/icon-512.png</Icon>
  <ExtraParams/>
  <PostArgs/>
  <CPUset/>
  <DateInstalled>0</DateInstalled>
  <DonateText/>
  <DonateLink/>
  <Description>A match-3 spellbound adventure with global leaderboards, daily challenges, cloud save, and a full admin UI -- all packed into one Docker container. SQLite database persists to /data inside the container; mount it to your Unraid appdata share.</Description>

  <Networking>
    <Mode>bridge</Mode>
    <Publish>
      <Port>
        <HostPort>8080</HostPort>
        <ContainerPort>3000</ContainerPort>
        <Protocol>tcp</Protocol>
      </Port>
    </Publish>
  </Networking>

  <Data>
    <Volume>
      <HostDir>/mnt/user/appdata/wizarding-nuts</HostDir>
      <ContainerDir>/data</ContainerDir>
      <Mode>rw</Mode>
    </Volume>
  </Data>

  <Environment>
    <Variable>
      <Value>3000</Value>
      <Name>PORT</Name>
      <Mode/>
    </Variable>
    <Variable>
      <Value>/data</Value>
      <Name>DATA_DIR</Name>
      <Mode/>
    </Variable>
    <Variable>
      <Value></Value>
      <Name>ADMIN_TOKEN</Name>
      <Mode/>
    </Variable>
  </Environment>

  <Labels/>

  <Config Name="WebUI Port"
          Target="3000"
          Default="8080"
          Mode="tcp"
          Description="Port the game + API listens on (host side)"
          Type="Port"
          Display="always"
          Required="true"
          Mask="false">8080</Config>

  <Config Name="Data Path"
          Target="/data"
          Default="/mnt/user/appdata/wizarding-nuts"
          Mode="rw"
          Description="Host folder for the SQLite database and server-published config.json"
          Type="Path"
          Display="always"
          Required="true"
          Mask="false">/mnt/user/appdata/wizarding-nuts</Config>

  <Config Name="Admin Token"
          Target="ADMIN_TOKEN"
          Default=""
          Mode=""
          Description="Set a long random string to enable 'Push to Server' in the admin panel. Leave blank to disable server-side admin push entirely. Generate one with: openssl rand -hex 32"
          Type="Variable"
          Display="always"
          Required="false"
          Mask="true"></Config>
</Container>
